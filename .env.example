# ── 服务端口（CloudBase 容器端口须与此一致，默认 3000）────────────────────────
PORT=3000

# ── 金山 WPS WebOffice（范本在线编辑）────────────────────────────────────────
# JSSDK 已内置在 public/vendor/，线上用相对路径即可
NEXT_PUBLIC_WPS_WEBOFFICE_SDK_URL=/vendor/web-office-sdk-solution-v2.0.7.umd.js

# 金山控制台 https://solution.wps.cn/console 创建应用后获取
WPS_WEBOFFICE_APP_ID=

# 服务端回调签名校验（勿提交仓库）
WPS_WEBOFFICE_APP_SECRET=

# 与控制台「接口调试」token 一致；生产环境按控制台要求填写
WPS_WEBOFFICE_TOKEN=

# 可选：控制台下发的 endpoint
# WPS_WEBOFFICE_ENDPOINT=

# 公网可访问的本服务根地址（不要末尾 /），须与 WPS 控制台「回调/网关」一致
# 例：https://fanben-demo-xxxxx.ap-shanghai.app.tcloudbase.com
WPS_CALLBACK_PUBLIC_BASE_URL=

# 可选：docx 持久化目录（CloudBase 云托管可挂载卷后设为 /data/documents）
# 未设置时默认 public/documents
# DOCUMENTS_DATA_DIR=/data/documents

# 可选：回调 users/permission 中的默认用户
# WPS_WEBOFFICE_DEFAULT_USER_ID=fanben_editor_user
# WPS_WEBOFFICE_DEFAULT_USER_NAME=编制用户
